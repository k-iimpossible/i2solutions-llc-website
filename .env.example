# Vercel: add these in Project → Settings → Environment Variables (Production / Preview / Development as needed)
# Local: copy to .env.local (never commit .env.local)

# Required — from https://resend.com/api-keys
RESEND_API_KEY=

# Inbound address for form submissions. Defaults to the test address in code if unset; override in production.
CONTACT_TO_EMAIL=digitaldroid420@gmail.com

# Optional — default is onboarding@resend.dev. After you verify a domain in Resend, set e.g. noreply@yourdomain.com
# RESEND_FROM_EMAIL=onboarding@resend.dev
